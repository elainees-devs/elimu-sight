{
  "compilerOptions": {
    /* ========================
       BASIC SETTINGS
    ======================== */
    "target": "ES2020",
    "module": "CommonJS",

    /* ========================
       PATHS
    ======================== */
    "rootDir": "./src",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "baseUrl": "./src",
    "paths": {
      "@routes/*": ["routes/*"],
      "@controllers/*": ["controllers/*"],
      "@middlewares/*": ["middlewares/*"], 
      "@services/*": ["services/*"],
      "@utils/*": ["utils/*"],
      "@config/*": ["config/*"]
    },
 

    /* ========================
       STRICTNESS
    ======================== */
    "strict": true,

     /* =========================
       MODULE RESOLUTION
    ========================= */
     "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,

    /* ========================
       QUALITY OF LIFE
    ======================== */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* ========================
       DEBUGGING
    ======================== */
    "sourceMap": true,

    /* ========================
       TYPES
    ======================== */
    "types": ["node", "jest"]
  },

   "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}